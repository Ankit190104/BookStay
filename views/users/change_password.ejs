<% layout("/layouts/boilerplate") %>

<div class="max-w-md mx-auto mt-10 sm:mt-16 px-4">
    <div class="bg-white dark:bg-gray-800 rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-gray-700 overflow-hidden">
        <div class="bg-primary p-8 text-white text-center">
            <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-4 border border-white/30">
                <i class="fa-solid fa-key text-2xl"></i>
            </div>
            <h2 class="text-2xl font-bold">Update Password</h2>
            <p class="text-sm opacity-80 mt-1">Keep your account safe and secure</p>
        </div>

        <form action="/change-password" method="POST" class="p-8 space-y-6 needs-validation" novalidate>
            <div>
                <label for="oldPassword" class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">Current Password</label>
                <div class="relative group">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary transition-colors">
                        <i class="fa-solid fa-lock-open text-sm"></i>
                    </span>
                    <input type="password" name="oldPassword" id="oldPassword" class="w-full pl-11 pr-4 py-3 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all dark:text-white" placeholder="••••••••" required>
                </div>
            </div>

            <hr class="border-gray-100 dark:border-gray-700">

            <div>
                <label for="newPassword" class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">New Password</label>
                <div class="relative group">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary transition-colors">
                        <i class="fa-solid fa-shield-halved text-sm"></i>
                    </span>
                    <input type="password" name="newPassword" id="newPassword" class="w-full pl-11 pr-4 py-3 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all dark:text-white" placeholder="••••••••" required minlength="6">
                </div>
            </div>

            <div>
                <label for="confirmPassword" class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">Confirm New Password</label>
                <div class="relative group">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary transition-colors">
                        <i class="fa-solid fa-circle-check text-sm"></i>
                    </span>
                    <input type="password" name="confirmPassword" id="confirmPassword" class="w-full pl-11 pr-4 py-3 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all dark:text-white" placeholder="••••••••" required>
                </div>
            </div>

            <button type="submit" class="w-full bg-primary text-white py-4 rounded-2xl font-bold text-lg hover:bg-primaryHover shadow-lg shadow-primary/20 transition-all active:scale-95 flex items-center justify-center space-x-2">
                <span>Update Password</span>
                <i class="fa-solid fa-arrow-right text-sm"></i>
            </button>
        </form>
    </div>

    <div class="mt-8 text-center">
        <a href="/profile" class="text-sm font-bold text-gray-500 hover:text-primary transition-colors no-underline">
            <i class="fa-solid fa-arrow-left mr-2"></i> Back to Profile
        </a>
    </div>
</div>

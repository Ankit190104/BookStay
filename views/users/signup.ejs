<% layout("/layouts/boilerplate") %>

<div class="max-w-md mx-auto mt-12 mb-20 px-4">
    <div class="bg-white dark:bg-gray-800 p-8 sm:p-10 rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-gray-700 transition-colors duration-300">
        <div class="text-center mb-10">
            <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <i class="fa-solid fa-user-plus text-primary text-2xl"></i>
            </div>
            <h2 class="text-3xl font-bold text-gray-800 dark:text-white">Create Account</h2>
            <p class="text-gray-500 dark:text-gray-400 mt-2 font-medium">Join our community of travelers.</p>
        </div>

        <form action="/signup" method="POST" class="needs-validation space-y-5" novalidate>
            <div>
                <label for="username" class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">Username</label>
                <div class="relative">
                    <span class="absolute left-5 top-4 text-gray-400"><i class="fa-solid fa-at text-sm"></i></span>
                    <input name="username" id="username" type="text" class="w-full pl-12 pr-5 py-4 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all dark:text-white placeholder:text-gray-400" placeholder="Choose a unique username" required>
                </div>
            </div>

            <div>
                <label for="email" class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">Email Address</label>
                <div class="relative">
                    <span class="absolute left-5 top-4 text-gray-400"><i class="fa-solid fa-envelope text-sm"></i></span>
                    <input name="email" id="email" type="email" class="w-full pl-12 pr-5 py-4 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all dark:text-white placeholder:text-gray-400" placeholder="your@email.com" required>
                </div>
            </div>

            <div>
                <label for="password" class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">Password</label>
                <div class="relative">
                    <span class="absolute left-5 top-4 text-gray-400"><i class="fa-solid fa-lock text-sm"></i></span>
                    <input name="password" id="password" type="password" class="w-full pl-12 pr-5 py-4 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all dark:text-white placeholder:text-gray-400" placeholder="Create a strong password" required>
                </div>
            </div>

            <div>
                <label class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-3">I want to...</label>
                <div class="grid grid-cols-2 gap-4">
                    <label class="relative flex flex-col p-4 border-2 border-gray-100 dark:border-gray-700 rounded-2xl cursor-pointer hover:border-primary/50 transition-all">
                        <input type="radio" name="role" value="guest" class="absolute top-4 right-4 text-primary focus:ring-primary" checked>
                        <i class="fa-solid fa-suitcase text-xl text-gray-400 mb-2"></i>
                        <span class="font-bold text-gray-800 dark:text-white text-sm">Book Stays</span>
                        <span class="text-[10px] text-gray-400">I am a traveler</span>
                    </label>
                    <label class="relative flex flex-col p-4 border-2 border-gray-100 dark:border-gray-700 rounded-2xl cursor-pointer hover:border-primary/50 transition-all">
                        <input type="radio" name="role" value="host" class="absolute top-4 right-4 text-primary focus:ring-primary">
                        <i class="fa-solid fa-house-user text-xl text-gray-400 mb-2"></i>
                        <span class="font-bold text-gray-800 dark:text-white text-sm">Host Home</span>
                        <span class="text-[10px] text-gray-400">I own a place</span>
                    </label>
                </div>
            </div>

            <button class="w-full bg-primary text-white py-4 rounded-2xl font-bold text-lg hover:bg-primaryHover transition-all shadow-lg shadow-primary/20 transform active:scale-[0.98] mt-4">Create Account</button>
        </form>

        <div class="mt-8 pt-8 border-t border-gray-100 dark:border-gray-700 text-center">
            <p class="text-gray-600 dark:text-gray-400 text-sm">Already have an account? <a href="/login" class="text-primary font-bold hover:underline">Sign in</a></p>
        </div>
    </div>
</div>
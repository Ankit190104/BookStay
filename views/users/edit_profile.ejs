<% layout("/layouts/boilerplate") %>

<div class="max-w-xl mx-auto mt-12 mb-20 px-4">
    <div class="bg-white dark:bg-gray-800 p-8 sm:p-10 rounded-[2.5rem] shadow-2xl border border-gray-100 dark:border-gray-700 transition-colors duration-300">
        <div class="text-center mb-10">
            <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <i class="fa-solid fa-user-gear text-primary text-2xl"></i>
            </div>
            <h2 class="text-3xl font-bold text-gray-800 dark:text-white">Edit Profile</h2>
            <p class="text-gray-500 dark:text-gray-400 mt-2 font-medium">Update your account information.</p>
        </div>

        <form action="/profile?_method=PUT" method="POST" class="needs-validation space-y-6" novalidate enctype="multipart/form-data">
            <!-- Current Photo Preview -->
            <div class="flex flex-col items-center mb-8">
                <div class="w-24 h-24 rounded-full overflow-hidden mb-4 border-4 border-white dark:border-gray-900 shadow-lg">
                    <img id="preview" src="<%= user.image.url %>" class="w-full h-full object-cover" alt="Current Photo">
                </div>
                <label for="image" class="cursor-pointer text-primary text-sm font-bold hover:underline">Change Photo</label>
                <input name="image" id="image" type="file" class="hidden" onchange="previewImage(event)">
            </div>

            <div>
                <label for="username" class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">Username</label>
                <input name="username" id="username" type="text" value="<%= user.username %>" class="w-full px-5 py-4 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all dark:text-white" required>
            </div>

            <div>
                <label for="email" class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">Email Address</label>
                <input name="email" id="email" type="email" value="<%= user.email %>" class="w-full px-5 py-4 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl focus:ring-4 focus:ring-primary/10 focus:border-primary outline-none transition-all dark:text-white" required>
            </div>

            <div class="pt-4 flex flex-col sm:flex-row gap-4">
                <button class="flex-1 bg-primary text-white py-4 rounded-2xl font-bold text-lg hover:bg-primaryHover transition-all shadow-lg transform active:scale-[0.98]">Save Changes</button>
                <a href="/profile" class="flex-1 bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-white py-4 rounded-2xl font-bold text-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-all text-center no-underline">Cancel</a>
            </div>
        </form>
    </div>
</div>

<script>
    function previewImage(event) {
        const reader = new FileReader();
        reader.onload = function() {
            const output = document.getElementById('preview');
            output.src = reader.result;
        }
        reader.readAsDataURL(event.target.files[0]);
    }
</script>

<% layout("/layouts/boilerplate") %>

<div class="max-w-4xl mx-auto px-4 mt-12 mb-20">
    <div class="bg-white dark:bg-gray-800 rounded-[3rem] shadow-2xl overflow-hidden border border-gray-100 dark:border-gray-700 transition-colors duration-300">
        <!-- Profile Header/Cover -->
        <div class="h-48 bg-gradient-to-r from-primary to-primaryHover relative">
            <div class="absolute -bottom-16 left-10">
                <div class="w-32 h-32 bg-white dark:bg-gray-900 rounded-full p-2 shadow-2xl">
                    <div class="w-full h-full rounded-full overflow-hidden border-4 border-white dark:border-gray-900 shadow-inner bg-primary flex items-center justify-center">
                        <% if (user.image && user.image.url && user.image.url !== "" && !user.image.url.includes("default_user_avatar")) { %>
                            <img src="<%= user.image.url %>" class="w-full h-full object-cover" alt="">
                        <% } else { %>
                            <span class="text-white text-5xl font-bold select-none">
                                <%= user.username.charAt(0).toUpperCase() %>
                            </span>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="pt-20 px-10 pb-12">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10">
                <div>
                    <h2 class="text-3xl font-bold text-gray-800 dark:text-white">@<%= user.username %></h2>
                    <p class="text-gray-500 dark:text-gray-400 font-medium flex items-center mt-1">
                        <i class="fa-solid fa-envelope mr-2 text-sm"></i> <%= user.email %>
                    </p>
                </div>
                <div class="mt-4 md:mt-0 flex space-x-3">
                    <span class="px-4 py-1.5 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-wider">
                        <%= user.role %>
                    </span>
                    <span class="px-4 py-1.5 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400 text-xs font-bold">
                        Joined <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %>
                    </span>
                </div>
            </div>

            <!-- Stats Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-12">
                <a href="/bookings" class="p-6 bg-gray-50 dark:bg-gray-900/50 rounded-3xl border border-gray-100 dark:border-gray-800 hover:border-primary transition-all no-underline group">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-10 h-10 bg-blue-50 dark:bg-blue-900/20 text-blue-500 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                            <i class="fa-solid fa-suitcase"></i>
                        </div>
                        <i class="fa-solid fa-chevron-right text-gray-300"></i>
                    </div>
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">My Bookings</p>
                    <h4 class="text-xl font-bold text-gray-800 dark:text-white mt-1"><%= bookingsCount %> Stays</h4>
                </a>

                <a href="/wishlist" class="p-6 bg-gray-50 dark:bg-gray-900/50 rounded-3xl border border-gray-100 dark:border-gray-800 hover:border-primary transition-all no-underline group">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-10 h-10 bg-red-50 dark:bg-red-900/20 text-red-500 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                            <i class="fa-solid fa-heart"></i>
                        </div>
                        <i class="fa-solid fa-chevron-right text-gray-300"></i>
                    </div>
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Saved Listings</p>
                    <h4 class="text-xl font-bold text-gray-800 dark:text-white mt-1"><%= user.wishlist.length %> Items</h4>
                </a>

                <% if (user.role === "host") { %>
                <a href="/listings/dashboard" class="p-6 bg-gray-50 dark:bg-gray-900/50 rounded-3xl border border-gray-100 dark:border-gray-800 hover:border-primary transition-all no-underline group">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-10 h-10 bg-green-50 dark:bg-green-900/20 text-green-500 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                            <i class="fa-solid fa-chart-line"></i>
                        </div>
                        <i class="fa-solid fa-chevron-right text-gray-300"></i>
                    </div>
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Host Dashboard</p>
                    <h4 class="text-xl font-bold text-gray-800 dark:text-white mt-1">Manage Business</h4>
                </a>
                <% } else { %>
                <div class="p-6 bg-primary/5 rounded-3xl border border-primary/10 flex flex-col justify-center text-center">
                    <p class="text-xs font-bold text-primary uppercase mb-2">Want to earn?</p>
                    <a href="/listings/new" class="text-sm font-bold text-gray-800 dark:text-white hover:underline">Register as a Host</a>
                </div>
                <% } %>
            </div>

            <div class="pt-8 border-t border-gray-50 dark:border-gray-700 flex flex-wrap gap-4">
                <a href="/profile/edit" class="px-8 py-3 bg-gray-900 dark:bg-gray-700 text-white rounded-xl font-bold text-sm hover:bg-black dark:hover:bg-gray-600 transition-all no-underline">Edit Profile</a>
                <a href="/change-password" class="px-8 py-3 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-700 rounded-xl font-bold text-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition-all no-underline">Change Password</a>
                <a href="/logout" class="px-8 py-3 border border-red-200 text-red-500 rounded-xl font-bold text-sm hover:bg-red-50 transition-all no-underline">Log Out</a>
            </div>

            <!-- Danger Zone -->
            <div class="mt-12 p-8 bg-red-50 dark:bg-red-900/10 rounded-3xl border border-red-100 dark:border-red-900/30">
                <h4 class="text-lg font-bold text-red-600 mb-2">Danger Zone</h4>
                <p class="text-sm text-red-500/80 mb-6 font-medium">Once you delete your account, there is no going back. Please be certain.</p>
                <form action="/profile?_method=DELETE" method="POST" onsubmit="return confirm('⚠️ CRITICAL: Are you absolutely sure you want to delete your account? This will permanently remove all your data.')">
                    <button class="px-8 py-3 bg-red-600 text-white rounded-xl font-bold text-sm hover:bg-red-700 transition-all shadow-lg shadow-red-600/20 active:scale-95">Delete My Account Permanently</button>
                </form>
            </div>
        </div>
    </div>
</div>

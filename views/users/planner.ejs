<% layout("/layouts/boilerplate") %>

<div class="max-w-4xl mx-auto px-4 mt-12 mb-20">
    <div class="text-center mb-16 animate-in fade-in slide-in-from-top-4 duration-700">
        <div class="inline-block p-4 bg-primary/10 rounded-[2rem] mb-6">
            <i class="fa-solid fa-wand-magic-sparkles text-primary text-4xl"></i>
        </div>
        <h2 class="text-4xl sm:text-5xl font-bold text-gray-800 dark:text-white mb-4">AI Travel Planner</h2>
        <p class="text-gray-500 dark:text-gray-400 text-lg max-w-2xl mx-auto">
            Tell us where you want to go, and our AI will craft a perfect 3-day itinerary for you.
        </p>
    </div>

    <div class="bg-white dark:bg-gray-800 p-8 sm:p-12 rounded-[3rem] shadow-2xl border border-gray-100 dark:border-gray-700 mb-12">
        <form id="planner-form" class="space-y-6">
            <div class="relative group">
                <label class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2 ml-2">Destination</label>
                <div class="relative">
                    <span class="absolute left-6 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary transition-colors">
                        <i class="fa-solid fa-location-dot"></i>
                    </span>
                    <input type="text" id="destination" name="destination" placeholder="e.g. Paris, Tokyo, Manali..." 
                        class="w-full pl-14 pr-6 py-5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-3xl outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary transition-all dark:text-white text-lg font-medium"
                        required>
                </div>
            </div>
            <button type="submit" id="generate-btn" class="w-full bg-gradient-to-r from-primary to-primaryHover text-white py-5 rounded-[1.5rem] font-bold text-xl shadow-xl shadow-primary/20 hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center justify-center space-x-3">
                <i class="fa-solid fa-sparkles"></i>
                <span>Generate My Itinerary</span>
            </button>
        </form>
    </div>

    <!-- Loading State -->
    <div id="loading" class="hidden text-center py-20 space-y-6">
        <div class="relative w-20 h-20 mx-auto">
            <div class="absolute inset-0 border-4 border-primary/20 rounded-full"></div>
            <div class="absolute inset-0 border-4 border-primary border-t-transparent rounded-full animate-spin"></div>
            <div class="absolute inset-0 flex items-center justify-center">
                <i class="fa-solid fa-paper-plane text-primary animate-pulse"></i>
            </div>
        </div>
        <p class="text-xl font-bold text-gray-800 dark:text-white animate-pulse">Planning your dream trip...</p>
        <p class="text-gray-500 text-sm">Searching for the best spots, restaurants, and hidden gems.</p>
    </div>

    <!-- Result Area -->
    <div id="itinerary-result" class="hidden space-y-8 animate-in fade-in slide-in-from-bottom-8 duration-700">
        <div class="flex items-center justify-between">
            <h3 class="text-2xl font-bold dark:text-white">Your 3-Day Adventure</h3>
            <button onclick="window.print()" class="p-3 rounded-xl border border-gray-200 dark:border-gray-700 text-gray-500 hover:text-primary transition-all">
                <i class="fa-solid fa-print"></i>
            </button>
        </div>
        <div id="itinerary-content" class="prose prose-pink dark:prose-invert max-w-none bg-white dark:bg-gray-800 p-8 sm:p-12 rounded-[2.5rem] shadow-xl border border-gray-100 dark:border-gray-700">
            <!-- AI Content Injected Here -->
        </div>
    </div>
</div>

<script>
    document.getElementById('planner-form').onsubmit = async (e) => {
        e.preventDefault();
        const destination = document.getElementById('destination').value;
        const btn = document.getElementById('generate-btn');
        const loading = document.getElementById('loading');
        const result = document.getElementById('itinerary-result');
        const content = document.getElementById('itinerary-content');

        // Reset
        result.classList.add('hidden');
        loading.classList.remove('hidden');
        btn.disabled = true;

        try {
            const res = await fetch('/planner/generate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ destination })
            });
            const data = await res.json();

            if (data.itinerary) {
                // Simple formatting for the returned text
                content.innerHTML = data.itinerary
                    .replace(/\n/g, '<br>')
                    .replace(/Day (\d)/g, '<h4 class="text-2xl font-bold text-primary mt-8 mb-4 border-b pb-2">Day $1</h4>')
                    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
                
                loading.classList.add('hidden');
                result.classList.remove('hidden');
                result.scrollIntoView({ behavior: 'smooth' });
            } else {
                alert(data.error || "Failed to generate itinerary");
                loading.classList.add('hidden');
            }
        } catch (err) {
            alert("Error connecting to AI");
            loading.classList.add('hidden');
        } finally {
            btn.disabled = false;
        }
    };
</script>

<style>
    /* Styling for the generated content */
    #itinerary-content h4 {
        color: #ff385c;
    }
    #itinerary-content ul {
        list-style-type: none;
        padding-left: 0;
    }
    #itinerary-content li {
        position: relative;
        padding-left: 1.5rem;
        margin-bottom: 0.75rem;
    }
    #itinerary-content li::before {
        content: "•";
        color: #ff385c;
        font-weight: bold;
        position: absolute;
        left: 0;
    }
</style>

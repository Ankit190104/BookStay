<% layout("/layouts/boilerplate") %>

<div class="max-w-7xl mx-auto px-4 mt-8 mb-20">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 pb-6 border-b border-gray-100 dark:border-gray-800">
        <div>
            <h2 class="text-3xl font-bold text-gray-800 dark:text-white">Host Dashboard</h2>
            <p class="text-gray-500 dark:text-gray-400 mt-1">Manage your properties and track your bookings.</p>
        </div>
        <a href="/listings/new" class="mt-4 md:mt-0 bg-primary text-white px-6 py-3 rounded-xl font-bold hover:bg-primaryHover transition-all flex items-center no-underline">
            <i class="fa-solid fa-plus mr-2"></i> Create New Listing
        </a>
    </div>

    <!-- Stats Section -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <div class="bg-white dark:bg-gray-800 p-6 rounded-3xl border border-gray-100 dark:border-gray-700 shadow-lg">
            <div class="w-12 h-12 bg-blue-50 dark:bg-blue-900/20 text-blue-500 rounded-2xl flex items-center justify-center mb-4">
                <i class="fa-solid fa-house-chimney text-xl"></i>
            </div>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Total Listings</p>
            <h3 class="text-2xl font-bold text-gray-800 dark:text-white mt-1"><%= myListings.length %></h3>
        </div>
        <div class="bg-white dark:bg-gray-800 p-6 rounded-3xl border border-gray-100 dark:border-gray-700 shadow-lg">
            <div class="w-12 h-12 bg-green-50 dark:bg-green-900/20 text-green-500 rounded-2xl flex items-center justify-center mb-4">
                <i class="fa-solid fa-calendar-check text-xl"></i>
            </div>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Bookings Received</p>
            <h3 class="text-2xl font-bold text-gray-800 dark:text-white mt-1"><%= receivedBookings.length %></h3>
        </div>
        <div class="bg-white dark:bg-gray-800 p-6 rounded-3xl border border-gray-100 dark:border-gray-700 shadow-lg">
            <div class="w-12 h-12 bg-purple-50 dark:bg-purple-900/20 text-purple-500 rounded-2xl flex items-center justify-center mb-4">
                <i class="fa-solid fa-indian-rupee-sign text-xl"></i>
            </div>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Estimated Earnings</p>
            <h3 class="text-2xl font-bold text-gray-800 dark:text-white mt-1">₹<%= receivedBookings.reduce((acc, curr) => acc + curr.totalPrice, 0).toLocaleString("en-IN") %></h3>
        </div>
        <div class="bg-white dark:bg-gray-800 p-6 rounded-3xl border border-gray-100 dark:border-gray-700 shadow-lg">
            <div class="w-12 h-12 bg-yellow-50 dark:bg-yellow-900/20 text-yellow-500 rounded-2xl flex items-center justify-center mb-4">
                <i class="fa-solid fa-star text-xl"></i>
            </div>
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Response Rate</p>
            <h3 class="text-2xl font-bold text-gray-800 dark:text-white mt-1">98%</h3>
        </div>
    </div>

    <!-- Revenue Chart & Quick Info -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 mb-12">
        <div class="lg:col-span-2 bg-white dark:bg-gray-800 p-8 rounded-[2.5rem] border border-gray-100 dark:border-gray-700 shadow-xl">
            <div class="flex justify-between items-center mb-8">
                <h3 class="text-xl font-bold text-gray-800 dark:text-white">Revenue Overview</h3>
                <span class="text-xs font-bold text-primary bg-primary/10 px-3 py-1 rounded-full uppercase">Last 6 Months</span>
            </div>
            <div class="h-64">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
        
        <div class="lg:col-span-1 bg-gradient-to-br from-gray-900 to-black p-8 rounded-[2.5rem] text-white shadow-2xl flex flex-col justify-between relative overflow-hidden">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-primary/20 rounded-full blur-3xl"></div>
            <div>
                <p class="text-primary font-bold text-xs uppercase tracking-widest mb-2">Host Tip</p>
                <h4 class="text-xl font-bold mb-4">Boost your bookings by 20%!</h4>
                <p class="text-gray-400 text-sm leading-relaxed">Hosts who reply to guests within 1 hour have a significantly higher booking rate. Keep up the great work!</p>
            </div>
            <button class="mt-8 bg-white text-black py-3 rounded-xl font-bold text-sm hover:bg-gray-100 transition-all">Optimization Guide</button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Recent Bookings Table -->
        <div class="lg:col-span-2">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-bold text-gray-800 dark:text-white">Recent Guest Bookings</h3>
            </div>
            
            <% if (receivedBookings.length > 0) { %>
                <div class="bg-white dark:bg-gray-800 rounded-3xl border border-gray-100 dark:border-gray-700 shadow-xl overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead>
                                <tr class="border-b border-gray-50 dark:border-gray-700">
                                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-widest">Guest</th>
                                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-widest">Listing</th>
                                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-widest">Dates</th>
                                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-widest">Status</th>
                                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-widest text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
                                <% for(let booking of receivedBookings) { %>
                                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-900/50 transition-colors">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center space-x-3">
                                                <div class="w-8 h-8 bg-primary/10 text-primary rounded-full flex items-center justify-center text-xs font-bold">
                                                    <%= booking.user.username[0].toUpperCase() %>
                                                </div>
                                                <span class="font-semibold text-gray-800 dark:text-gray-200">@<%= booking.user.username %></span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="text-sm font-medium text-gray-600 dark:text-gray-400 line-clamp-1"><%= booking.listing.title %></span>
                                        </td>
                                        <td class="px-6 py-4">
                                            <p class="text-xs font-bold text-gray-800 dark:text-gray-200"><%= booking.checkIn.toLocaleDateString() %></p>
                                        </td>
                                        <td class="px-6 py-4">
                                            <% if (booking.status === 'pending') { %>
                                                <span class="bg-yellow-100 text-yellow-600 px-3 py-1 rounded-full text-[10px] font-bold uppercase">Pending</span>
                                            <% } else if (booking.status === 'confirmed') { %>
                                                <span class="bg-green-100 text-green-600 px-3 py-1 rounded-full text-[10px] font-bold uppercase">Approved</span>
                                            <% } else { %>
                                                <span class="bg-red-100 text-red-600 px-3 py-1 rounded-full text-[10px] font-bold uppercase">Rejected</span>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            <% if (booking.status === 'pending') { %>
                                                <div class="flex justify-end space-x-2">
                                                    <form action="/bookings/<%= booking._id %>/approve?_method=PATCH" method="POST">
                                                        <button class="bg-green-500 text-white p-2 rounded-lg hover:bg-green-600 transition-all shadow-sm"><i class="fa-solid fa-check text-xs"></i></button>
                                                    </form>
                                                    <form action="/bookings/<%= booking._id %>/reject?_method=PATCH" method="POST">
                                                        <button class="bg-red-500 text-white p-2 rounded-lg hover:bg-red-600 transition-all shadow-sm"><i class="fa-solid fa-xmark text-xs"></i></button>
                                                    </form>
                                                </div>
                                            <% } else { %>
                                                <span class="text-xs text-gray-400 font-medium">No actions</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            <% } else { %>
                <div class="bg-gray-50 dark:bg-gray-800/30 rounded-[2rem] border-2 border-dashed border-gray-200 dark:border-gray-700 p-12 text-center">
                    <p class="text-gray-500">No bookings received yet. Your properties are waiting for guests!</p>
                </div>
            <% } %>
        </div>

        <!-- My Listings Column -->
        <div class="lg:col-span-1">
            <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-6">Manage My Listings</h3>
            <div class="space-y-4">
                <% if (myListings.length > 0) { %>
                    <% for(let listing of myListings) { %>
                        <div class="flex items-center space-x-4 p-3 bg-white dark:bg-gray-800 rounded-2xl border border-gray-100 dark:border-gray-700 shadow-sm hover:shadow-md transition-all">
                            <div class="w-16 h-16 rounded-xl overflow-hidden flex-shrink-0">
                                <img src="<%= listing.image.url %>" class="w-full h-full object-cover" alt="">
                            </div>
                            <div class="flex-1 min-w-0">
                                <h4 class="text-sm font-bold text-gray-800 dark:text-white truncate"><%= listing.title %></h4>
                                <p class="text-xs text-gray-500 dark:text-gray-400">₹<%= listing.price.toLocaleString("en-IN") %>/night</p>
                            </div>
                            <div class="flex space-x-1">
                                <a href="/listings/<%= listing._id %>/edit" class="p-2 text-gray-400 hover:text-primary transition-colors"><i class="fa-solid fa-pen-to-square"></i></a>
                                <a href="/listings/<%= listing._id %>" class="p-2 text-gray-400 hover:text-blue-500 transition-colors"><i class="fa-solid fa-eye"></i></a>
                            </div>
                        </div>
                    <% } %>
                <% } else { %>
                    <div class="p-6 bg-gray-50 dark:bg-gray-800/30 rounded-2xl border border-gray-100 dark:border-gray-700 text-center">
                        <p class="text-xs text-gray-500 mb-4">You haven't listed any property yet.</p>
                        <a href="/listings/new" class="text-sm font-bold text-primary hover:underline">Start Hosting</a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

    <!-- Hidden Chart Data -->
    <div id="chart-data" data-labels='<%- chartLabels %>' data-values='<%- chartData %>'></div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const chartDataEl = document.getElementById('chart-data');
        const labels = JSON.parse(chartDataEl.dataset.labels);
        const dataValues = JSON.parse(chartDataEl.dataset.values);

        const ctx = document.getElementById('revenueChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Monthly Earnings (₹)',
                    data: dataValues,
                borderColor: '#ff385c',
                backgroundColor: 'rgba(255, 56, 92, 0.1)',
                tension: 0.4,
                fill: true,
                pointBackgroundColor: '#ff385c',
                pointBorderColor: '#fff',
                pointBorderWidth: 2,
                pointRadius: 6,
                pointHoverRadius: 8
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { color: 'rgba(0, 0, 0, 0.05)' },
                    ticks: {
                        callback: function(value) { return '₹' + value.toLocaleString(); }
                    }
                },
                x: {
                    grid: { display: false }
                }
            }
        }
    });
</script>

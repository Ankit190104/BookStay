<% layout("/layouts/boilerplate") %>

<div class="max-w-xl mx-auto mt-20 mb-32 px-4 text-center">
    <div class="bg-red-50 dark:bg-red-900/20 p-12 rounded-[3rem] border border-red-100 dark:border-red-900/30 shadow-2xl transition-colors duration-300">
        <div class="w-24 h-24 bg-white dark:bg-gray-800 rounded-3xl shadow-xl flex items-center justify-center mx-auto mb-8 transform -rotate-6">
            <i class="fa-solid fa-circle-exclamation text-red-500 text-5xl"></i>
        </div>
        
        <h2 class="text-4xl font-black text-gray-900 dark:text-white mb-4">Something went wrong!</h2>
        
        <div class="bg-white/60 dark:bg-black/20 backdrop-blur-sm p-6 rounded-2xl mb-8 border border-red-200 dark:border-red-900/20">
            <p class="text-red-600 dark:text-red-400 font-mono text-sm break-words"><%= message %></p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/listings" class="bg-gray-900 dark:bg-white text-white dark:text-gray-900 px-8 py-3.5 rounded-2xl font-bold hover:bg-black dark:hover:bg-gray-100 transition-all shadow-lg no-underline flex items-center justify-center">
                <i class="fa-solid fa-house-chimney mr-2"></i> Back to Home
            </a>
            <button onclick="window.location.reload()" class="bg-white dark:bg-gray-800 text-gray-800 dark:text-white border border-gray-200 dark:border-gray-700 px-8 py-3.5 rounded-2xl font-bold hover:bg-gray-50 dark:hover:bg-gray-700 transition-all no-underline">
                Try Again
            </button>
        </div>
    </div>
</div>
